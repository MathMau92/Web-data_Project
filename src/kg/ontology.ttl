@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix ex: <http://example.org/vg/> .

# --- Classes ---

ex:VideoGame a owl:Class ;
    rdfs:label "Jeu Vidéo"@fr ;
    rdfs:comment "Une application logicielle de type jeu vidéo."@fr ;
    rdfs:subClassOf schema:SoftwareApplication .

ex:Platform a owl:Class ;
    rdfs:label "Plateforme"@fr ;
    rdfs:comment "Le support matériel sur lequel le jeu s'exécute (PS5, PC, etc.)."@fr .

# --- Propriétés (Relations) ---

ex:hasPlatform a owl:ObjectProperty ;
    rdfs:label "est supporté par"@fr ;
    rdfs:domain ex:VideoGame ;
    rdfs:range ex:Platform .

ex:releaseDate a owl:DatatypeProperty ;
    rdfs:label "date de sortie"@fr ;
    rdfs:domain ex:VideoGame ;
    rdfs:range xsd:date .

ex:title a owl:DatatypeProperty ;
    rdfs:label "titre original"@fr ;
    rdfs:domain ex:VideoGame ;
    rdfs:range xsd:string .